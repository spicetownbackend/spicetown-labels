# ─── Spice Town Labels — environment template ───────────────────────────────
# Copy to `.env` and adjust. All settings have safe defaults (see config.py).

# Environment: development | production | testing
STL_ENV=development
STL_SECRET_KEY=change-me-in-production

# ── Data provider (adapter switch) ──────────────────────────────────────────
# file  -> read products.csv / products.json
# toast -> Toast POS (OAuth2 stub; implement provider before enabling)
STL_DATA_PROVIDER=file
STL_PRODUCTS_FILE=./data/products.csv

# ── Toast (only needed when STL_DATA_PROVIDER=toast) ────────────────────────
STL_TOAST_CLIENT_ID=
STL_TOAST_CLIENT_SECRET=
STL_TOAST_RESTAURANT_GUID=
STL_TOAST_API_BASE=https://ws-api.toasttab.com

# ── Database ─────────────────────────────────────────────────────────────────
# STL_DATABASE_URI=sqlite:////absolute/path/spicetown.db

# ── Cache TTLs (seconds) ─────────────────────────────────────────────────────
STL_CACHE_TTL_STANDARD=86400   # 24h
STL_CACHE_TTL_FLAGGED=3600     # 1h
STL_CACHE_MISS_WARN_RATIO=0.05 # warn above 5% miss rate in the window

# ── Rate limiter ─────────────────────────────────────────────────────────────
STL_RATE_LIMIT_RATE=10         # req/s sustained
STL_RATE_LIMIT_BURST=20        # bucket capacity

# ── Backoff (429 / 5xx) ──────────────────────────────────────────────────────
STL_BACKOFF_BASE=0.5
STL_BACKOFF_MAX=30
STL_BACKOFF_MAX_RETRIES=5

# ── Print mode ───────────────────────────────────────────────────────────────
# local  -> this process prints (transport below). Use when the app runs at
#           the store on the same network as the printer.
# remote -> jobs queue in SQLite; the store's print-bridge agent
#           (scripts/print_bridge.py) polls /api/bridge and prints. Use when
#           the app is hosted in the cloud. See docs/BRIDGE.md.
STL_PRINT_MODE=local
# Shared secret for the bridge API (required in remote mode; give the same
# value to the bridge agent). Generate one: python -c "import secrets;print(secrets.token_hex(24))"
STL_BRIDGE_TOKEN=
# Re-queue a claimed job if the bridge doesn't report back within this window.
STL_BRIDGE_STALE_SECONDS=300

# ── Printing (Brother QL-810W) ──────────────────────────────────────────────
# Transport: cups | brother_ql | file | null
STL_PRINT_TRANSPORT=cups
STL_CUPS_PRINTER_NAME=Brother_QL_810W
# Extra `lp -o` options, comma-separated. Example for a 29x62mm DK-1209 label
# in landscape at 123% scale (omit fit-to-page; scaling auto-disables it):
#   STL_CUPS_LP_OPTIONS=media=29x62mm,landscape,scaling=123
# STL_CUPS_LP_OPTIONS=
STL_CUPS_FIT_TO_PAGE=true       # set false (or use scaling=) for manual sizing
STL_LABEL_SIZE=62              # mm continuous default; "29x62" = DK-1209 landscape
STL_LABEL_DPI=300
STL_LABEL_LENGTH_PX=390        # printed length for continuous tape
STL_PRINTER_MODEL=QL-810W
STL_PRINTER_BACKEND=linux_kernel   # brother_ql backend: linux_kernel|pyusb|network
STL_PRINTER_DEVICE=/dev/usb/lp0
# STL_PRINT_SPOOL_DIR=./spool   # used by the 'file' transport
STL_ENABLE_PRINT_WORKER=true
STL_PRINT_QUEUE_MAXSIZE=100
STL_PRINT_TIMEOUT=20
STL_PRINT_MAX_RETRIES=2

# ── Bulk load / nightly refresh ──────────────────────────────────────────────
STL_LOAD_ON_STARTUP=true       # warm SQLite from the source on boot
STL_BULK_LOAD_BATCH_SIZE=500   # commit cadence during a bulk load
STL_ENABLE_SCHEDULER=true
STL_REFRESH_HOUR=3
STL_REFRESH_MINUTE=0
STL_SCHEDULER_TIMEZONE=America/New_York

# ── AI features (Stage 4) ───────────────────────────────────────────────────
STL_LABEL_NAME_MAX_CHARS=22    # auto-shorten product names to fit the label
STL_SEARCH_LIMIT=5             # max fuzzy-search suggestions
STL_SEARCH_NAME_CUTOFF=60      # rapidfuzz score cutoff for name search (0-100)
STL_SEARCH_UPC_CUTOFF=70       # rapidfuzz score cutoff for misread-UPC search

# ── Logging ──────────────────────────────────────────────────────────────────
STL_LOG_LEVEL=INFO
STL_LOG_MAX_BYTES=5242880      # 5 MB
STL_LOG_BACKUP_COUNT=7
